{
  "manifest_version": 3,
  "name": "eXsite AI Shopping Assistant",
  "version": "2.0",
  "description": "AI-powered price tracking, cross-marketplace comparison, and smart shopping assistant.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*",
        "*://*.amazon.com/*",
        "*://*.flipkart.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "*://*.amazon.in/*",
    "*://*.amazon.com/*",
    "*://*.flipkart.com/*",
    "*://*.supabase.co/*",
    "http://127.0.0.1:8000/*"
  ]
}
